{
    "name": "Imgur Fix",
    "version": "1.0.1",
    "description": "Reroutes direct Imgur images via the DuckDuckGo Proxy",
    "manifest_version": 2,
    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "webNavigation",
        "tabs",
        "storage",
        "<all_urls>"
    ],
    "browser_action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "imgur-fix@extension",
            "strict_min_version": "140.0",
            "update_url": "https://addons.mydevserver.uk/updates.json",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}